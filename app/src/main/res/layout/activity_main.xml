<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerlayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:id="@+id/rootScroll">
        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">



        <!-- Şehir Arama Kartı -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="15dp"
            app:cardBackgroundColor="#000000">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp">

                <AutoCompleteTextView
                    android:id="@+id/editTextCity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Şehir adı girin"
                    android:inputType="text"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:textColor="#ffffff"
                    android:completionThreshold="1"/>

                <Button
                    android:id="@+id/buttonSearch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ara"
                    android:textColor="#ffffff"
                    android:backgroundTint="#4f6d7a"
                    android:padding="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="0dp"
    android:gravity="center">

    <!-- Mevcut Konum Butonu -->
    <Button
        android:id="@+id/buttonCurrentLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Mevcut Konum"
        android:textColor="#ffffff"
        android:backgroundTint="#5A5B68"
        android:textSize="14sp"
        android:padding="12dp"
        android:layout_marginEnd="5dp"
        android:fontFamily="sans-serif-medium"
        app:cornerRadius="15dp"/>
<!-- Kayıtlı veriyi temizle butonu -->
    <Button
        android:id="@+id/buttonClearAll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:layout_weight="1"
        android:enabled="true"
        android:fontFamily="sans-serif-medium"
        android:padding="12dp"
        android:text="Verileri Temizle"
        android:textColor="#ffffff"
        android:backgroundTint="#5A5B68"
        android:textSize="14sp"
        app:cornerRadius="15dp" />
</LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="5dp"
        android:gravity="center">

        <!-- Favorilere ekle Butonu -->
        <Button
            android:id="@+id/buttonAddFavori"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Favorilere Ekle"
            android:textColor="#ffffff"
            android:backgroundTint="#5A5B68"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginEnd="5dp"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="15dp"/>

        <!-- Favorileri temizle Butonu -->
        <Button
            android:id="@+id/buttondeleteALlFavori"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Favorileri Sil"
            android:textColor="#ffffff"
            android:backgroundTint="#5A5B68"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginStart="5dp"
            android:enabled="true"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="15dp"/>
    </LinearLayout>
        <!-- Hava Durumu Bilgi Kartı -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="15dp"
            app:cardBackgroundColor="#33FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="25dp"
                android:gravity="center">


                <!-- Şehir Adı -->
                <TextView
                    android:id="@+id/textViewCityName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Şehir Seçin"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1f2937"
                    android:layout_marginBottom="15dp"/>

                <!-- Son Güncelleme -->
                <TextView
                    android:id="@+id/textViewLastUpdate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Son güncelleme: --"
                    android:textSize="11sp"
                    android:textColor="#1f2937"
                    android:layout_marginBottom="15dp" />

                <!-- Hava İkonu -->
                <ImageView
                    android:id="@+id/imageViewWeatherIcon"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/icon_sunny"
                    android:layout_marginBottom="15dp"/>

                <!-- Sıcaklık -->
                <TextView
                    android:id="@+id/textViewTemperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°C"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:textColor="#1f2937"
                    android:layout_marginBottom="10dp"/>

                <!-- Hava Durumu Açıklaması -->
                <TextView
                    android:id="@+id/textViewDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hava durumu bilgisi"
                    android:textSize="20sp"
                    android:textColor="#1f2937"
                    android:layout_marginBottom="20dp"/>

                <!-- Detay Bilgileri Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- İlk Satır -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="15dp">

                        <!-- Nem Bilgisi -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:src="@drawable/icon_humidity"
                                android:layout_gravity="center"
                                android:layout_marginTop="5dp"/>

                            <TextView
                                android:id="@+id/textViewHumidity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nem: --%"
                                android:textSize="13sp"
                                android:textColor="#1f2937"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="15dp"
                                android:layout_marginBottom="0dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:layout_marginTop="1dp"
                                android:layout_marginBottom="16dp"
                                android:text="📊"
                                android:textSize="30sp"
                                android:layout_gravity="center_horizontal"/>

                            <TextView
                                android:id="@+id/textViewPressure"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Basınç: -- hPa"
                                android:textColor="#1f2937"
                                android:textSize="13sp"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginBottom="0dp"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- İkinci Satır -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!--Rüzgar Bilgileri -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:id="@+id/imageViewWindTurbine"
                                android:layout_width="48dp"
                                android:rotation="0"
                                android:scaleType="centerInside"
                                android:layout_height="48dp"
                                android:src="@drawable/winddirection"
                                android:layout_margin="0dp"/>

                            <TextView
                                android:id="@+id/textViewWindSpeed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rüzgar: -- m/s"
                                android:textSize="13sp"
                                android:textColor="#1f2937"/>
                        </LinearLayout>

                        <!-- Bulutluluk durumu-->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:src="@drawable/icon_cloudy"
                                android:layout_marginBottom="7dp"/>
                            <TextView
                                android:id="@+id/textViewCloudiness"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bulut Oranı: %0"
                                android:textSize="13sp"
                                android:textColor="#1f2937"/>

                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 5 Günlük Tahmin Butonu -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center">
            <Button
                android:id="@+id/buttonForecast"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="5 Günlük Tahmin"
                android:textColor="#ffffff"
                android:backgroundTint="#5A5B68"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="15dp"
                android:enabled="false"
                android:layout_marginEnd="5dp"
                app:cornerRadius="15dp"/>

            <Button
                android:id="@+id/buttonHourlyForecast"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text=" 72 Saatlik Tahmin"
                android:textColor="#ffffff"
                android:backgroundTint="#5A5B68"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="15dp"
                android:enabled="false"
                android:layout_marginStart="5dp"
                app:cornerRadius="15dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="0dp"
        android:layout_gravity="start">


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerFavorites"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="0dp"
            android:padding="0dp"
            android:scrollbars="vertical"/>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>