<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#55000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp">

        <!-- Sol taraf - İkon ve Sıcaklık -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
/
            <ImageView
                android:id="@+id/imageViewIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/icon_sunny"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/textViewTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25°C"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#ffd54f"/>
        </LinearLayout>

        <!-- Sağ taraf - Detay Bilgileri -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="vertical"
            android:paddingStart="15dp"
            android:paddingEnd="10dp">

            <!-- Tarih -->
            <TextView
                android:id="@+id/textViewDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01 Ocak 2024 - Pazartesi"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:layout_marginBottom="5dp"/>

            <!-- Açıklama -->
            <TextView
                android:id="@+id/textViewDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parçalı bulutlu"
                android:textSize="13sp"
                android:textColor="#e0e0e0"
                android:layout_marginBottom="8dp"/>

            <!-- Min/Max Sıcaklık -->
            <TextView
                android:id="@+id/textViewTempRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Min: 18°C / Max: 28°C"
                android:textSize="12sp"
                android:textColor="#cccccc"
                android:layout_marginBottom="8dp"/>

            <!-- Nem ve Rüzgar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textViewHumidity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💧 Nem: 65%"
                    android:textSize="11sp"
                    android:textColor="#cccccc"/>

                <TextView
                    android:id="@+id/textViewWind"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💨 Rüzgar: 5 m/s"
                    android:textSize="11sp"
                    android:textColor="#cccccc"/>
            </LinearLayout>
            <!-- Nem ve Rüzgar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textViewRain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 mm"
                    android:textSize="11sp"
                    android:textColor="#aaaaaa"/>

                <TextView
                    android:id="@+id/textViewRainProbability"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="% 0"
                    android:textSize="11sp"
                    android:textColor="#aaaaaa"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>